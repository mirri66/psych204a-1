      "for p in range(num_particles):\n",
      "    ax.plot((start_xy[0,p], xy[0,p]), (start_xy[1,p], xy[1,p]), linewidth=1, color=[.5, .5, .5], linestyle='solid')"
     ],
     "language": "python",
